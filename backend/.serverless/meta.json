    "serviceRawFile": "service: enap-booking-backend\n\nuseDotenv: true\n\n# Deshabilitar integración con el Dashboard de Serverless (para uso 100% gratuito y local)\ndashboard: false\n\nprovider:\n  name: aws\n  runtime: nodejs20.x\n  stage: ${opt:stage, 'prod'}\n  region: ${opt:region, 'us-east-1'}\n  profile: new-account # Perfil de AWS CLI para los despliegues\n  \n  environment:\n    NODE_ENV: production\n    DB_HOST: ${env:DB_HOST, 'ab-cl-prod.c05eu0eyenew.us-east-1.rds.amazonaws.com'}\n    DB_PORT: ${env:DB_PORT, '3306'}\n    DB_USERNAME: ${env:DB_USERNAME, 'enap_booking_user'}\n    DB_PASSWORD: ${env:DB_PASSWORD}\n    DB_DATABASE: ${env:DB_DATABASE, 'enap_booking'}\n    DB_SYNCHRONIZE: ${env:DB_SYNCHRONIZE, 'false'}\n    DB_MIGRATIONS_RUN: ${env:DB_MIGRATIONS_RUN, 'true'}\n    DB_CONNECTION_LIMIT: ${env:DB_CONNECTION_LIMIT, '2'} # Optimizado para entornos serverless\n    JWT_SECRET: ${env:JWT_SECRET}\n    JWT_EXPIRATION: ${env:JWT_EXPIRATION, '24h'}\n    ALLOWED_ORIGINS: ${env:ALLOWED_ORIGINS}\n    # AWS_ACCESS_KEY_ID: ${env:AWS_ACCESS_KEY_ID}\n    # AWS_SECRET_ACCESS_KEY: ${env:AWS_SECRET_ACCESS_KEY}\n    # AWS_REGION: ${env:AWS_REGION, 'us-east-1'}\n    AWS_S3_BUCKET: ${env:AWS_S3_BUCKET, 'enap-booking-bucket'}\n    SMTP_HOST: ${env:SMTP_HOST, 'email-smtp.us-east-1.amazonaws.com'}\n    SMTP_PORT: ${env:SMTP_PORT, '587'}\n    SMTP_USER: ${env:SMTP_USER}\n    SMTP_PASS: ${env:SMTP_PASS}\n    SMTP_FROM: ${env:SMTP_FROM}\n    ADMIN_EMAIL: ${env:ADMIN_EMAIL}\n    MP_PUBLIC_KEY: ${env:MP_PUBLIC_KEY}\n    MP_ACCESS_TOKEN: ${env:MP_ACCESS_TOKEN}\n    MP_ID_APP: ${env:MP_ID_APP}\n    MP_USER_ID: ${env:MP_USER_ID}\n\n  # Configuración de VPC (Descomentar si la RDS está en una VPC privada y no tiene acceso público)\n  # vpc:\n  #   securityGroupIds:\n  #     - sg-XXXXXXXXXXXXXXXXX # ID del Security Group que permite acceso a la base de datos\n  #   subnetIds:\n  #     - subnet-XXXXXXXXXXXXXXXXX # Subnets privadas con salida a internet (NAT Gateway) para la Lambda\n  #     - subnet-YYYYYYYYYYYYYYYYY\n\npackage:\n  patterns:\n    - '!src/**'\n    - '!test/**'\n    - '!tsconfig.build.json'\n    - '!tsconfig.json'\n    - '!eslint.config.mjs'\n    - '!nest-cli.json'\n    - '!README.md'\n    - '!package-lock.json'\n    - '!src/data-source.ts'\n    - 'dist/**'\n    - 'node_modules/**'\n    - '.env'\n\nfunctions:\n  api:\n    handler: dist/lambda.handler\n    timeout: 30 # Segundos (límite máximo recomendado para API Gateway)\n    memorySize: 1024 # MB (se puede ajustar según las necesidades de performance/costo)\n    events:\n      - httpApi:\n          path: '/'\n          method: any\n      - httpApi:\n          path: '/{proxy+}'\n          method: any\n",
